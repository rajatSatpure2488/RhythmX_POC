# MediSync — Environment Variables
# ⚠️  NEVER commit this file to version control

# DrChrono OAuth Credentials
DRCHRONO_CLIENT_ID=your_client_id_here
DRCHRONO_CLIENT_SECRET=your_client_secret_here
DRCHRONO_REDIRECT_URI=http://localhost:8000/auth/oauth/callback

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend Dev Server
VITE_API_BASE_URL=http://localhost:8000

# Token Security
TOKEN_ENCRYPTION_KEY=your_32_byte_key_here

# Rate Limits (DrChrono defaults)
DRCHRONO_DAILY_LIMIT=500
DRCHRONO_MINUTE_LIMIT=29
